# ═══════════════════════════════════════════
#  Stream Monitoring Service - Configuration
# ═══════════════════════════════════════════

# ─── Environment ───
# "development" = JSON file storage (no database needed)
# "production"  = Prisma database storage (MySQL/PostgreSQL)
NODE_ENV=development

# ─── Database (PRODUCTION ONLY) ───
# Provider: "mysql" or "postgresql"
DATABASE_PROVIDER=mysql
DATABASE_URL="mysql://user:password@localhost:3306/stream_monitor"

# ─── Server ───
PORT=3000
HOST=0.0.0.0

# Set to "true" to disable IP whitelist (DEVELOPMENT ONLY!)
DISABLE_IP_WHITELIST=true

# ─── Security ───
# Comma-separated whitelist: IPs and domains (auto-detected)
# IPs (start with digit/contain ':'): added to IP whitelist
# Domains: added to CORS allowed origins (https:// auto-prefixed if no scheme)
# Example: WHITELIST=1.2.3.4,your-frontend.com,http://localhost:3000
WHITELIST=http://localhost:3000,https://your-frontend.com

# ─── Logging ───
# Options: debug, info, warn, error
LOG_LEVEL=info
